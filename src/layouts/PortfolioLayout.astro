---
import Analytics from '@vercel/analytics/astro';
import TweaksPanel from '../components/TweaksPanel.astro';
import '../styles/portfolio.css';

interface Props {
  title: string;
  description: string;
  siteName: string;
  themeColor: string;
  keywords: string;
  canonicalUrl?: string;
  ogImageUrl: string;
  structuredData: string;
}

const { title, description, siteName, themeColor, keywords, canonicalUrl, ogImageUrl, structuredData } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="Angel Cilfone" />
    <meta name="keywords" content={keywords} />
    <meta name="theme-color" content={themeColor} />
    <meta name="format-detection" content="telephone=no" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Portfolio preview for Angel Cilfone, full stack developer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Portfolio preview for Angel Cilfone, full stack developer" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <script is:inline type="application/ld+json" set:html={structuredData}></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <TweaksPanel />
    <Analytics />
  </body>
</html>
