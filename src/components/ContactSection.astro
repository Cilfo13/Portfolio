---
import { contactLinks } from '../data/portfolio';
import SectionHeading from './SectionHeading.astro';
---

<section id="contact">
  <SectionHeading label="// contact" centered>
    Let's <span class="grad-text">connect</span>
  </SectionHeading>

  <div class="contact-card fade-in-up delay-1">
    <div class="contact-glow"></div>
    <div class="contact-avail">
      <span class="contact-avail-dot"></span>
      Open to opportunities
    </div>
    <p class="contact-msg">
      Available for remote backend and full stack opportunities.<br />
      I reply within 24 hours.
    </p>
    <div class="contact-links">
      {contactLinks.map((link) => (
        <a href={link.href} class="contact-link" target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>
          <div class:list={['contact-link-icon', link.variant]}>
            {link.variant === 'email' ? (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="2" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="M22 7l-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"></path>
              </svg>
            ) : (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22d3ee" stroke-width="2" aria-hidden="true">
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            )}
          </div>
          <div>
            <span>{link.label}</span>
            <span class="contact-link-sub">{link.sublabel}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
